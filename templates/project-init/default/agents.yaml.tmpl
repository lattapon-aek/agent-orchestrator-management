roles:
  orchestrator:
    class: orchestrator
    worktree_mode: read-only
    checkpoint_expectation: required
    default_session_mode: interactive

  backend:
    class: builder
    worktree_mode: dedicated-writer
    checkpoint_expectation: required
    default_session_mode: interactive

  reviewer:
    class: reviewer
    worktree_mode: read-only
    checkpoint_expectation: required
    default_session_mode: interactive

agents:
  orchestrator-main:
    runtime: claude
    role: orchestrator
    enabled: true
    # model: sonnet  # optional: sonnet | opus | haiku | claude-sonnet-4-6 | claude-opus-4-7

  backend-main:
    runtime: codex
    role: backend
    enabled: true
    # model: gpt-5.3-codex  # optional: gpt-5.5 | gpt-5.4 | gpt-5.4-mini | gpt-5.3-codex

  reviewer-main:
    runtime: claude
    role: reviewer
    enabled: true
    # model: sonnet  # optional: sonnet | opus | haiku | claude-sonnet-4-6 | claude-opus-4-7
